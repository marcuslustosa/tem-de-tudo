APP_NAME="Tem de Tudo"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://tem-de-tudo.onrender.com
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=pgsql
DATABASE_URL=
DB_HOST=your-database-host.render.com
DB_PORT=5432
DB_DATABASE=your_database_name
DB_USERNAME=your_database_user
DB_PASSWORD=your_secure_password_here
DB_SSLMODE=require
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=tdt_

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Web Push (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# JWT Configuration
JWT_SECRET=
JWT_TTL=1440
JWT_REFRESH_TTL=20160

# Wallet Passes
GOOGLE_WALLET_ADD_URL=
APPLE_WALLET_DOWNLOAD_URL=
CLIENT_QR_CODE_TTL=3600

# Firebase Configuration
FIREBASE_SERVER_KEY=
FIREBASE_PROJECT_ID=

# MercadoPago Configuration
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=

# Storage Configuration
FILESYSTEM_DISK=public

# OpenAI Configuration
OPENAI_API_KEY=

# Error monitoring (optional)
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2

# Container startup controls
RUN_MIGRATIONS_ON_START=true
SEED_ON_START=false
RUN_QUEUE_WORKER_ON_START=true
RUN_SCHEDULER_ON_START=true
QUEUE_WORKER_TRIES=3
QUEUE_WORKER_MAX_TIME=3600
ENSURE_DEMO_ACCESS_ON_START=true
DEMO_FORCE_PASSWORD_RESET=true
VERIFY_FRONTEND_ON_START=true
AUTO_FIX_FRONTEND_ASSETS=true

# Demo access provisioning (perfil admin/empresa/cliente)
DEMO_ACCESS_ENABLED=true
DEMO_ADMIN_EMAIL=admin.demo@temdetudo.com
DEMO_ADMIN_NAME="Admin Demo"
DEMO_ADMIN_PASSWORD="DemoAdmin@2026!"
DEMO_EMPRESA_EMAIL=empresa.demo@temdetudo.com
DEMO_EMPRESA_NAME="Empresa Demo"
DEMO_EMPRESA_PASSWORD="DemoEmpresa@2026!"
DEMO_EMPRESA_RAZAO="Empresa Demo Tem de Tudo"
DEMO_EMPRESA_CNPJ="98.765.432/0001-10"
DEMO_CLIENTE_EMAIL=cliente.demo@temdetudo.com
DEMO_CLIENTE_NAME="Cliente Demo"
DEMO_CLIENTE_PASSWORD="DemoCliente@2026!"

# Optional manual setup endpoint (disabled by default)
ALLOW_SETUP_ENDPOINT=false
SETUP_DATABASE_TOKEN=
SETUP_DATABASE_RUN_SEED=false

# Scheduler HTTP endpoint token (required if SchedulerController routes are exposed)
SCHEDULER_TOKEN=

# Billing compatibility mode
BILLING_ALLOW_WITHOUT_SUBSCRIPTION=true

# Billing retries / dunning
BILLING_RETRY_ENABLED=true
BILLING_RETRY_MAX_ATTEMPTS=3
BILLING_RETRY_BACKOFF_DAYS=1,3,5

# Billing reconciliation
BILLING_RECONCILIATION_ENABLED=true
BILLING_RECONCILIATION_LOOKBACK_DAYS=30

# Idempotency behavior
IDEMPOTENCY_ENFORCE_HEADER=true
IDEMPOTENCY_REQUIRE_IN_PRODUCTION=true
IDEMPOTENCY_ALLOW_BYPASS_NON_PRODUCTION=true
IDEMPOTENCY_DEFAULT_TTL=3600

# Privacy / LGPD
PRIVACY_CONSENT_VERSION=v1
PRIVACY_EXPORT_DISK=local
PRIVACY_EXPORT_ROW_LIMIT=5000
