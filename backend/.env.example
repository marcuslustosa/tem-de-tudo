APP_NAME="Tem de Tudo"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://tem-de-tudo.onrender.com
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=pgsql
DATABASE_URL=
DB_HOST=your-database-host.render.com
DB_PORT=5432
DB_DATABASE=your_database_name
DB_USERNAME=your_database_user
DB_PASSWORD=your_secure_password_here
DB_SSLMODE=require
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=tdt_

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Web Push (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# JWT Configuration
JWT_SECRET=
JWT_TTL=1440
JWT_REFRESH_TTL=20160

# Wallet Passes
GOOGLE_WALLET_ADD_URL=
APPLE_WALLET_DOWNLOAD_URL=
CLIENT_QR_CODE_TTL=3600

# Firebase Configuration
FIREBASE_SERVER_KEY=
FIREBASE_PROJECT_ID=

# MercadoPago Configuration
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=

# Storage Configuration
FILESYSTEM_DISK=public

# OpenAI Configuration
OPENAI_API_KEY=

# Container startup controls
RUN_MIGRATIONS_ON_START=true
SEED_ON_START=false
RUN_QUEUE_WORKER_ON_START=true
RUN_SCHEDULER_ON_START=true
QUEUE_WORKER_TRIES=3
QUEUE_WORKER_MAX_TIME=3600

# Optional manual setup endpoint (disabled by default)
ALLOW_SETUP_ENDPOINT=false
SETUP_DATABASE_TOKEN=
SETUP_DATABASE_RUN_SEED=false

# Scheduler HTTP endpoint token (required if SchedulerController routes are exposed)
SCHEDULER_TOKEN=
