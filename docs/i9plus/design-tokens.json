{
  "brand": {
    "name": "i9Plus inspired loyalty PWA",
    "goal": "Adaptar o PWA existente para um app/site de fidelização com QR Code, empresas, promoções, bônus e campanhas.",
    "reusePolicy": "Reaproveitar a base atual sempre que possível. Não recriar arquitetura sem necessidade."
  },
  "responsiveBehavior": {
    "mobile": {
      "experience": "app-like",
      "navigation": "bottom navigation",
      "layout": "single column",
      "focus": "QR Code, empresas, promoções e ações rápidas",
      "cards": "stacked",
      "buttons": "large pill buttons"
    },
    "desktop": {
      "experience": "website/admin panel",
      "navigation": "sidebar or top navigation",
      "layout": "wide responsive layout",
      "tables": "allowed for admin and reports",
      "forms": "can use two columns",
      "note": "Desktop não deve ser apenas o layout mobile esticado."
    }
  },
  "colors": {
    "primaryNavy": "#111B3F",
    "primaryBlue": "#133F8C",
    "primaryTeal": "#00AFA8",
    "primaryMagenta": "#B01774",
    "accentPink": "#E91E85",
    "background": "#F7F7F7",
    "surface": "#FFFFFF",
    "surfaceMuted": "#F1F1F1",
    "textPrimary": "#1E1E1E",
    "textSecondary": "#8A8A8A",
    "textInverse": "#FFFFFF",
    "border": "#E4E4E4",
    "success": "#00AFA8",
    "warning": "#FFC107",
    "danger": "#E53935",
    "darkHeader": "#080A12"
  },
  "gradients": {
    "main": "linear-gradient(135deg, #133F8C 0%, #00AFA8 48%, #B01774 100%)",
    "companyHighlight": "linear-gradient(90deg, #00AFA8 0%, #133F8C 45%, #B01774 100%)",
    "tealToBlue": "linear-gradient(135deg, #00AFA8 0%, #133F8C 100%)",
    "magentaToNavy": "linear-gradient(135deg, #B01774 0%, #111B3F 100%)"
  },
  "typography": {
    "fontFamily": "'Inter', 'Montserrat', Arial, sans-serif",
    "appTitle": {
      "fontSize": "26px",
      "fontWeight": "800"
    },
    "sectionTitle": {
      "fontSize": "20px",
      "fontWeight": "800"
    },
    "cardTitle": {
      "fontSize": "18px",
      "fontWeight": "800"
    },
    "body": {
      "fontSize": "14px",
      "fontWeight": "400"
    },
    "caption": {
      "fontSize": "12px",
      "fontWeight": "400"
    },
    "button": {
      "fontSize": "14px",
      "fontWeight": "800"
    }
  },
  "radius": {
    "sm": "8px",
    "md": "14px",
    "lg": "20px",
    "xl": "28px",
    "pill": "999px"
  },
  "spacing": {
    "xs": "4px",
    "sm": "8px",
    "md": "16px",
    "lg": "24px",
    "xl": "32px"
  },
  "shadows": {
    "card": "0 8px 24px rgba(0,0,0,0.08)",
    "modal": "0 18px 45px rgba(0,0,0,0.22)",
    "button": "0 6px 14px rgba(0,0,0,0.12)"
  },
  "layout": {
    "mobileMaxWidth": "430px",
    "desktopContentMaxWidth": "1180px",
    "bottomNavHeight": "68px",
    "pagePaddingMobile": "20px",
    "pagePaddingDesktop": "32px"
  }
}
