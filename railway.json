{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "restartPolicyType": "ALWAYS",
    "healthcheckPath": "/api/ping",
    "preDeployCommand": "cd /var/www/html && php artisan migrate --force --no-interaction"
  }
}
