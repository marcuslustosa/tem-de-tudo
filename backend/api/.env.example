# API
PORT=3001
JWT_SECRET=defina-um-segredo-forte

# Banco (PostgreSQL na Railway)
# Use o domínio privado para o app (porta 5432) e o público apenas para acesso externo/psql.
DATABASE_URL="postgresql://postgres:<SENHA>@<RAILWAY_PRIVATE_DOMAIN>:5432/railway"
DATABASE_PUBLIC_URL="postgresql://postgres:<SENHA>@<RAILWAY_TCP_PROXY_DOMAIN>:<RAILWAY_TCP_PROXY_PORT>/railway"
