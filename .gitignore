*.log
logs/
storage/logs/
backend/storage/logs/

# Ignorar temporarios
tmp/
temp/
*.tmp
*.bak
*.swp

# Ignorar arquivos do sistema
.DS_Store
Thumbs.db

# Ignorar relatorios de cobertura de testes
coverage/
